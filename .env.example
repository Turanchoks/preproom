# openssl rand -base64 32
AUTH_SECRET=****

# MCP demo token (optional — allows demo@preproom.app access without password)
# PREPROOM_MCP_DEMO_TOKEN=

# Postgres (local dev or Cloud SQL)
POSTGRES_URL=postgres://postgres@localhost:5432/teachflow

# Gemini (https://aistudio.google.com/apikey) — both vars, same key
GOOGLE_GENERATIVE_AI_API_KEY=****
GOOGLE_API_KEY=****

# Agent: 1 = ADK agent path, 0 = plain AI SDK fallback
USE_ADK=1

# Video pipeline: direct = analyze in-process (local dev), pubsub = Cloud Run
PUBSUB_MODE=direct
# GOOGLE_CLOUD_PROJECT=
# GCS_BUCKET=
# PUBSUB_TOPIC=video-analyze
# PUBSUB_PUSH_SA_EMAIL=
# PUSH_ENDPOINT_URL=
